<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="CalculatorController">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <Label text="Calculator with Database" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Label text="Number 1:"/>
    <TextField fx:id="number1Field" promptText="Enter Number 1"/>

    <Label text="Number 2:"/>
    <TextField fx:id="number2Field" promptText="Enter Number 2"/>

    <!-- Operation buttons in a 2x2 grid -->
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Button text="➕ Add"       onAction="#onAddClick"      GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity"/>
        <Button text="➖ Subtract"  onAction="#onSubtractClick" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>
        <Button text="✖ Multiply"  onAction="#onMultiplyClick" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
        <Button text="➗ Divide"    onAction="#onDivideClick"   GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="110"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="110"/>
        </columnConstraints>
    </GridPane>

    <Label fx:id="resultLabel" style="-fx-font-size: 14px; -fx-text-fill: #2a6ebb;"/>

</VBox>

